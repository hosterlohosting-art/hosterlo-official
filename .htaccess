# Hosterlo .htaccess - Redirects & Configuration
# ================================================

# Custom 404 Error Page
ErrorDocument 404 /404.html

# Enable Rewrite Engine
RewriteEngine On

# Block direct access to Git and deployment metadata if this folder is used as a Git working tree
RedirectMatch 404 /\.git
RedirectMatch 404 /\.cpanel\.yml
RedirectMatch 404 /\.github

# Force HTTPS on production
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 301 Redirects: old flat-file URLs to directory URLs
RewriteRule ^hosting\.html$ /hosting/ [R=301,L]
RewriteRule ^contact\.html$ /contact-us/ [R=301,L]
RewriteRule ^blog\.html$ /blog/ [R=301,L]
RewriteRule ^legal\.html$ /legal/ [R=301,L]
RewriteRule ^support\.html$ /support/ [R=301,L]
RewriteRule ^free-tools\.html$ /free-tools/ [R=301,L]
RewriteRule ^login\.html$ /login/ [R=301,L]

# 301 Redirects: old pages that do not exist on the live site
RewriteRule ^seo-hosting\.html$ /hosting/ [R=301,L]
RewriteRule ^infrastructure\.html$ /infrastructure/ [R=301,L]
RewriteRule ^global-reach\.html$ /infrastructure/ [R=301,L]
RewriteRule ^services\.html$ /services/ [R=301,L]
RewriteRule ^enterprise-infrastructure\.html$ /infrastructure/ [R=301,L]
RewriteRule ^domains\.html$ /domains/ [R=301,L]
RewriteRule ^register-domain\.html$ /domains/ [R=301,L]
RewriteRule ^domain-transfer\.html$ /domains/ [R=301,L]

# 301 Redirects: old or hidden WordPress slugs
RewriteRule ^website-builder/?$ /hosting/ [R=301,L]
RewriteRule ^web-security/?$ /hosting/shared-hosting/ [R=301,L]
RewriteRule ^email/?$ /hosting/ [R=301,L]
RewriteRule ^buy-1-year-get-1-year-free-hosting-offer/?$ /free-offer/ [R=301,L]
RewriteRule ^elementor-3888/?$ / [R=301,L]
RewriteRule ^refund_policy/?$ /refund-policy/ [R=301,L]
RewriteRule ^contact/?$ /contact-us/ [R=301,L]
RewriteRule ^global-reach/?$ /infrastructure/ [R=301,L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# WebP image support
<IfModule mod_mime.c>
    AddType image/webp .webp
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 10 minutes"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
