# Hosterlo .htaccess - Redirects & Configuration
# ================================================

# Custom 404 Error Page
ErrorDocument 404 /404.html

# Enable Rewrite Engine
RewriteEngine On

# Block direct access to Git and deployment metadata if this folder is used as a Git working tree
RedirectMatch 404 /\.git
RedirectMatch 404 /\.cpanel\.yml
RedirectMatch 404 /\.github

# Force HTTPS on production
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 301 Redirects: old flat-file URLs to directory URLs
RewriteRule ^hosting\.html$ /hosting/ [R=301,L]
RewriteRule ^contact\.html$ /contact-us/ [R=301,L]
RewriteRule ^blog\.html$ /blog/ [R=301,L]
RewriteRule ^legal\.html$ /legal/ [R=301,L]
RewriteRule ^support\.html$ /contact-us/ [R=301,L]
RewriteRule ^free-tools\.html$ /free-tools/ [R=301,L]
RewriteRule ^login\.html$ https://billing.hosterlo.com/index.php?rp=%2Flogin [R=301,L]

# 301 Redirects: old pages that do not exist on the live site
RewriteRule ^seo-hosting\.html$ /hosting/ [R=301,L]
RewriteRule ^infrastructure\.html$ /about-hosterlo/ [R=301,L]
RewriteRule ^global-reach\.html$ /about-hosterlo/ [R=301,L]
RewriteRule ^services\.html$ /hosting/ [R=301,L]
RewriteRule ^enterprise-infrastructure\.html$ /about-hosterlo/ [R=301,L]
RewriteRule ^domains\.html$ /domains/ [R=301,L]
RewriteRule ^register-domain\.html$ /domains/ [R=301,L]
RewriteRule ^domain-transfer\.html$ /domains/ [R=301,L]

# 301 Redirects: old or hidden slugs / directories
RewriteRule ^website-builder/?$ /hosting/ [R=301,L]
RewriteRule ^web-security/?$ /hosting/shared-hosting/ [R=301,L]
RewriteRule ^email/?$ /hosting/ [R=301,L]
RewriteRule ^buy-1-year-get-1-year-free-hosting-offer/?$ /hosting/ [R=301,L]
RewriteRule ^elementor-3888/?$ / [R=301,L]
RewriteRule ^refund_policy/?$ /refund-policy/ [R=301,L]
RewriteRule ^contact/?$ /contact-us/ [R=301,L]
RewriteRule ^global-reach/?$ /about-hosterlo/ [R=301,L]

# New directory redirects
RewriteRule ^free-offer/?$ /hosting/ [R=301,L]
RewriteRule ^infrastructure/?$ /about-hosterlo/ [R=301,L]
RewriteRule ^digioverse/?$ /about-hosterlo/ [R=301,L]
RewriteRule ^support/?$ /contact-us/ [R=301,L]
# RewriteRule ^services/?$ /hosting/ [R=301,L] (Disabled: Services hub is live)
RewriteRule ^login/?$ https://billing.hosterlo.com/index.php?rp=%2Flogin [R=301,L]
RewriteRule ^business-email-hosting/?$ /hosting/business-email/ [R=301,L]
RewriteRule ^compare/?$ / [R=301,L]
RewriteRule ^about-us/?$ /about-hosterlo/ [R=301,L]
RewriteRule ^about/?$ /about-hosterlo/ [R=301,L]
KeepAlive On

# UK and PK Subdirectory Redirects
RewriteRule ^uk/free-offer/?$ /uk/hosting/ [R=301,L]
RewriteRule ^pk/free-offer/?$ /pk/hosting/ [R=301,L]
RewriteRule ^uk/infrastructure/?$ /uk/about-hosterlo/ [R=301,L]
RewriteRule ^pk/infrastructure/?$ /pk/about-hosterlo/ [R=301,L]
RewriteRule ^uk/digioverse/?$ /uk/about-hosterlo/ [R=301,L]
RewriteRule ^pk/digioverse/?$ /pk/about-hosterlo/ [R=301,L]
RewriteRule ^uk/support/?$ /uk/contact-us/ [R=301,L]
RewriteRule ^pk/support/?$ /pk/contact-us/ [R=301,L]
RewriteRule ^uk/services/?$ /services/ [R=301,L]
RewriteRule ^pk/services/?$ /services/ [R=301,L]
RewriteRule ^uk/business-email-hosting/?$ /uk/hosting/business-email/ [R=301,L]
RewriteRule ^pk/business-email-hosting/?$ /pk/hosting/business-email/ [R=301,L]
RewriteRule ^uk/compare/?$ /uk/ [R=301,L]
RewriteRule ^pk/compare/?$ /pk/ [R=301,L]
RewriteRule ^uk/about-us/?$ /uk/about-hosterlo/ [R=301,L]
RewriteRule ^pk/about-us/?$ /pk/about-hosterlo/ [R=301,L]
RewriteRule ^uk/about/?$ /uk/about-hosterlo/ [R=301,L]
RewriteRule ^pk/about/?$ /pk/about-hosterlo/ [R=301,L]

# Redirect index.html to trailing slash
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)/index\.html\ HTTP/
RewriteRule ^(.+)/index\.html$ /%1/ [R=301,L]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ / [R=301,L]

# Security headers
<IfModule mod_headers.c>
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# WebP image support + XML sitemap MIME type
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType application/xml .xml
    AddType text/xml .xml
</IfModule>

# Ensure XML sitemaps are not blocked
<IfModule mod_headers.c>
    <FilesMatch "\.(xml)$">
        Header set Content-Type "application/xml; charset=utf-8"
        Header set X-Robots-Tag "noindex"
    </FilesMatch>
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 10 minutes"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
